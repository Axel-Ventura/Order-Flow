# ─────────────────────────────────────────────────────────────
#  OrderFlow Backend — Variables de Entorno
#  Copia este archivo como .env y completa los valores reales.
# ─────────────────────────────────────────────────────────────

# ─── SERVIDOR ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── SUPABASE ─────────────────────────────────────────────────
# URL del proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (pública, solo para clientes — opcional en backend)
SUPABASE_KEY=tu_anon_key

# Service Role Key — NUNCA expongas esta key al frontend
# Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=tu_service_role_key

# ─── JWT ──────────────────────────────────────────────────────
# Secreto para firmar Access Tokens (mínimo 32 caracteres, idealmente 64+)
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio

# Duración del Access Token (15m, 1h, etc.)
JWT_EXPIRES_IN=15m

# Secreto para firmar Refresh Tokens (diferente al de access token)
JWT_REFRESH_SECRET=otro_secreto_diferente_y_muy_largo_para_refresh

# Duración del Refresh Token (7d, 30d, etc.)
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios extras)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── SEGURIDAD ────────────────────────────────────────────────
# Rondas de bcrypt para hash de contraseñas (10-14 recomendado)
BCRYPT_ROUNDS=12
